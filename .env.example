# ============================================================
# VARIABLES DE ENTORNO - Citrino Bot
# Copiá este archivo como ".env" y completá los valores
# ============================================================

# Token de verificación (inventate uno, puede ser cualquier texto, ej: citrino2024)
VERIFY_TOKEN=citrino2024

# API Key de Anthropic (Claude)
# Conseguila en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ---- META / WhatsApp Business ----
# Token de acceso de larga duración de tu app Meta
META_ACCESS_TOKEN=EAAxxxxx...

# ID del número de teléfono de WhatsApp Business
# Lo encontrás en Meta for Developers > Tu App > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=1234567890

# ---- Facebook Messenger ----
# ID de tu página de Facebook
FACEBOOK_PAGE_ID=1234567890

# Token de acceso de la página (distinto al META_ACCESS_TOKEN)
META_PAGE_ACCESS_TOKEN=EAAxxxxx...

# ---- Instagram ----
# ID de tu cuenta de Instagram Business (vinculada a la página de Facebook)
INSTAGRAM_PAGE_ID=1234567890

# ---- Google Calendar & Sheets ----
# ID del calendario (normalmente es tu email de Google, ej: vos@gmail.com)
# Si querés usar un calendario separado, copiá el ID desde Calendar > Configuración
GOOGLE_CALENDAR_ID=vos@gmail.com

# ID del Google Sheet del CRM
# Lo encontrás en la URL: docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Service Account JSON (todo en una línea, entre comillas simples)
# Descargá el archivo JSON desde Google Cloud Console y pegá su contenido acá
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"citrino-bot@tu-proyecto.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Puerto (Railway lo asigna automáticamente, no toques esto)
PORT=3000
