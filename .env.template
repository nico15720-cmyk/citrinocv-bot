# ============================================================
# CITRINO BOT — Variables de entorno
# Copiá este archivo como ".env" y completá los valores
# NUNCA subas el archivo .env a GitHub
# ============================================================


# ── GENERAL ─────────────────────────────────────────────────

# Inventate un texto cualquiera (ej: citrino2024)
# Tiene que coincidir con lo que pongas en el Webhook de Meta
VERIFY_TOKEN=citrino2024


# ── ANTHROPIC (Claude AI) ────────────────────────────────────

# Conseguilo en: https://console.anthropic.com → API Keys → Create Key
# Cargá al menos $5 USD de crédito (alcanzan para miles de conversaciones)
ANTHROPIC_API_KEY=sk-ant-...


# ── META / WHATSAPP BUSINESS ─────────────────────────────────

# Token de acceso permanente de tu app de Meta
# Dónde conseguirlo:
#   1. developers.facebook.com → Tu App → WhatsApp → API Setup
#   2. Generá un System User en Business Manager con token permanente
META_ACCESS_TOKEN=EAAxxxxx...

# ID del número de teléfono de WhatsApp Business
# Dónde conseguirlo: developers.facebook.com → Tu App → WhatsApp → API Setup
# Ejemplo: 123456789012345
WHATSAPP_PHONE_NUMBER_ID=


# ── FACEBOOK MESSENGER ───────────────────────────────────────

# ID de tu Página de Facebook
# Dónde conseguirlo: facebook.com/tu-pagina → Sobre esta página → ID de página
FACEBOOK_PAGE_ID=

# Token de acceso de la Página (diferente al META_ACCESS_TOKEN)
# Dónde conseguirlo: developers.facebook.com → Tu App → Messenger → Configuración → Tokens de acceso
META_PAGE_ACCESS_TOKEN=EAAxxxxx...


# ── INSTAGRAM ────────────────────────────────────────────────

# ID de tu cuenta de Instagram Business (vinculada a tu Página de Facebook)
# Dónde conseguirlo: developers.facebook.com → Tu App → Instagram → Configuración básica
INSTAGRAM_PAGE_ID=


# ── GOOGLE CALENDAR ──────────────────────────────────────────

# ID del calendario que quiere usar el bot
# Si es el calendario principal, ponés tu email de Gmail
# Si es un calendario separado, copiá el ID desde:
#   Google Calendar → click en el calendario → Configuración → ID del calendario
# Ejemplo: natalia@gmail.com  o  c_abc123@group.calendar.google.com
GOOGLE_CALENDAR_ID=


# ── GOOGLE SHEETS (CRM) ──────────────────────────────────────

# ID del Google Sheet donde se guardan los clientes
# Dónde conseguirlo: abrí el Sheet y mirá la URL:
#   docs.google.com/spreadsheets/d/[ESTE_ES_EL_ID]/edit
GOOGLE_SHEETS_ID=


# ── GOOGLE SERVICE ACCOUNT ───────────────────────────────────

# Contenido completo del archivo JSON de la Service Account, en UNA SOLA LÍNEA
# Pasos para conseguirlo:
#   1. console.cloud.google.com → Credenciales → Crear credenciales → Cuenta de servicio
#   2. Descargá la clave en formato JSON
#   3. Abrí el archivo JSON, copiá TODO el contenido y pegalo acá entre comillas simples
# Ejemplo: {"type":"service_account","project_id":"citrino-bot","private_key_id":"abc",...}
GOOGLE_SERVICE_ACCOUNT_JSON=


# ── SERVIDOR ─────────────────────────────────────────────────

# Railway asigna el puerto automáticamente. No toques esto.
PORT=3000
